PORT=3000
NODE_ENV=production

# Database
MONGODB_URI=mongodb+srv://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_CLUSTER.mongodb.net/leveldevil?retryWrites=true&w=majority&appName=LevelDevil

# Auth
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars

# Render / deployment
RENDER_EXTERNAL_URL=https://your-render-app.onrender.com

# Metrics protection
METRICS_KEY=admin

# HTTP rate limiting
HTTP_RATE_WINDOW_MS=60000
HTTP_RATE_LIMIT_DEFAULT=120
HTTP_RATE_LIMIT_AUTH=30
HTTP_RATE_LIMIT_FEEDBACK=12
HTTP_RATE_LIMIT_FRIENDS=60
HTTP_RATE_LIMIT_SCORES=60

# Socket anti-spam limits
SOCKET_RATE_WINDOW_MS=1000
SOCKET_RATE_LIMIT_GAME_STATE=90
SOCKET_RATE_LIMIT_GAME_INPUT=120
SOCKET_RATE_LIMIT_GAME_EVENT=90
SOCKET_RATE_LIMIT_SIGNAL=180
SOCKET_RATE_LIMIT_PING=20
SOCKET_RATE_LIMIT_ROOM=20

# Optional Playwright / local testing
PLAYWRIGHT_PORT=3020
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3020

# Optional stress test target
STRESS_URL=https://your-render-app.onrender.com
STRESS_ROOMS=4
STRESS_PLAYERS=4
STRESS_MS=12000
STRESS_STATE_MS=33
STRESS_INPUT_MS=50
